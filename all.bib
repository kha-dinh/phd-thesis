@article{zhangviper,
  title = {Viper: {{A Fast Snapshot Isolation Checker}}},
  author = {Zhang, Jian and Ji, Ye and Mu, Shuai and Tan, Cheng},
  abstract = {Snapshot isolation (SI) is supported by most commercial databases
              and is widely used by applications. However, checking SI today
              \textemdash given a set of transactions, checking if they obey SI
              \textemdash is either slow or gives up soundness. We present viper,
              an SI checker that is sound, complete, and fast. Viper checks
              black-box databases and hence is transparent to both users and
              databases. To be fast, viper introduces BC-polygraphs, a new
              representation of transaction dependencies. A BC-polygraph is
              acyclic iff transactions are SI, a theorem that we prove. Viper
              also introduces heuristic pruning, an optimization to accelerate
              checking SI by leveraging common knowledge of real-world database
              implementations. Besides vanilla SI, viper supports major SI
              variants including Strong SI, Generalized SI, and Strong Session
              SI. Our experiments show that given the same time budget, viper
              improves over baselines by 15\texttimes{} in the workload sizes
              being checked.},
}

@inproceedings{zhao2022vsgx,
  title = {{{vSGX}}: {{Virtualizing SGX Enclaves}} on {{AMD SEV}}},
  shorttitle = {{{vSGX}}},
  booktitle = {2022 {{IEEE Symp}}. {{Secur}}. {{Priv}}. {{SP}}},
  author = {Zhao, Shixuan and Li, Mengyuan and Zhangyz, Yinqian and Lin,
            Zhiqiang},
  year = 2022,
  month = may,
  pages = {321--336},
  abstract = {The growing need of trusted execution environment (TEE) has boomed
              the development of hardware enclaves. However, current TEEs and
              their applications are tightly bound to the hardware implementation
              , hindering their compatibility across different platforms. This
              paper presents vSGX, a novel system to virtualize the execution of
              an Intel SGX enclave atop AMD SEV. The key idea is to interpose the
              execution of enclave instructions transparently to support the SGX
              ISA extensions, consolidate encrypted virtual memory of separated
              SEV virtual machines to create a single virtualized SGX-like
              address space, and provide attestations for the authenticity of the
              TEE and the integrity of enclave software with a trust chain rooted
              in the SEV hardware. By design, vSGX achieves a comparable level of
              security guarantees on SEV as that on Intel SGX. We have
              implemented vSGX and demonstrated it imposes reasonable performance
              overhead for SGX enclave execution.},
  annotation = {6 citations (Semantic Scholar/DOI) [2023-05-18]},
}

