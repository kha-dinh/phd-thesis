@inproceedings{xu2021infat,
  title = {In-Fat Pointer: Hardware-Assisted Tagged-Pointer Spatial Memory
           Safety Defense with Subobject Granularity Protection},
  shorttitle = {In-Fat Pointer},
  booktitle = {Proc. 26th {{ACM Int}}. {{Conf}}. {{Archit}}. {{Support Program}}
               . {{Lang}}. {{Oper}}. {{Syst}}.},
  author = {Xu, Shengjie and Huang, Wei and Lie, David},
  year = 2021,
  month = apr,
