@inproceedings{crane_thwarting_2015,
	address = {San Diego, CA},
	title = {Thwarting {Cache} {Side}-{Channel} {Attacks} {Through} {Dynamic} {Software} {Diversity}},
	isbn = {978-1-891562-38-9},
	url = {https://www.ndss-symposium.org/ndss2015/ndss-2015-programme/thwarting-cache-side-channel-attacks-through-dynamic-software-diversity/},
