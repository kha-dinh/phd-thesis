@article{kolosick_isolation_2022,
	title = {Isolation without taxation: near-zero-cost transitions for {WebAssembly} and {SFI}},
	volume = {6},
	issn = {2475-1421},
	shorttitle = {Isolation without taxation},
	url = {https://dl.acm.org/doi/10.1145/3498688},
	doi = {10.1145/3498688},
	abstract = {Software sandboxing or software-based fault isolation (SFI) is a lightweight approach to building secure systems out of untrusted components. Mozilla, for example, uses SFI to harden the Firefox browser by sandboxing third-party libraries, and companies like Fastly and Cloudflare use SFI to safely co-locate untrusted tenants on their edge clouds. While there have been significant efforts to optimize and verify SFI enforcement, context switching in SFI systems remains largely unexplored: almost all SFI systems use
              heavyweight transitions
              that are not only error-prone but incur significant performance overhead from saving, clearing, and restoring registers when context switching. We identify a set of
              zero-cost conditions
              that characterize when sandboxed code has sufficient structured to guarantee security via lightweight
              zero-cost
