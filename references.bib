	author = {Jero, Samuel and Burow, Nathan and Ward, Bryan and Skowyra, Richard and Khazan, Roger and Shrobe, Howard and Okhravi, Hamed},
	month = jul,
	year = {2023},
	note = {3 citations (Semantic Scholar/DOI) [2023-07-05]},
	pages = {1--34},
}

